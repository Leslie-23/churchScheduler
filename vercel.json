{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/auth/(.*)", "dest": "server.js" },
    { "src": "/app/app.js", "dest": "/app/app.js" },
    { "src": "/app/style.css", "dest": "/app/style.css" },
    { "src": "/app(.*)", "dest": "/app/index.html" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/(.*\\.css)", "dest": "/public/$1" },
    { "src": "/(.*\\.js)", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
